{
  "name": "@truspec/web",
  "version": "0.6.0",
  "description": "TruSpec web UI + local server (truspec serve).",
  "type": "module",
  "license": "MIT",
  "author": "Rashid Mahmood",
  "homepage": "https://code-with-rashid.github.io/truspec/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-with-rashid/truspec.git",
    "directory": "packages/web"
  },
  "bugs": "https://github.com/code-with-rashid/truspec/issues",
  "keywords": ["truspec", "api-client", "openapi", "ui", "local-first"],
  "publishConfig": { "access": "public" },
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build",
    "build:server": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/ibm-plex-sans": "^5.1.0",
    "@truspec/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
