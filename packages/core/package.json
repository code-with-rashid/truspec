{
  "name": "@truspec/core",
  "version": "0.6.0",
  "description": "TruSpec engine: collection format, request runner, OpenAPI drift & coverage, importers, mock.",
  "type": "module",
  "license": "MIT",
  "author": "Rashid Mahmood",
  "homepage": "https://code-with-rashid.github.io/truspec/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-with-rashid/truspec.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/code-with-rashid/truspec/issues",
  "keywords": ["api", "openapi", "http", "testing", "local-first", "drift", "coverage", "mock", "agent"],
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./runner": {
      "types": "./dist/runner/index.d.ts",
      "import": "./dist/runner/index.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "import": "./dist/workspace/index.js"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "import": "./dist/spec/index.js"
    },
    "./importers": {
      "types": "./dist/importers/index.d.ts",
      "import": "./dist/importers/index.js"
    },
    "./mock": {
      "types": "./dist/mock/index.d.ts",
      "import": "./dist/mock/index.js"
    },
    "./schema/*": "./schema/*"
  },
  "files": ["dist", "schema"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "gen:schema": "node scripts/emit-schema.mjs"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
