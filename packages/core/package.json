{
  "name": "@truspec/core",
  "version": "0.0.0",
  "description": "TruSpec engine: collection format, request runner, OpenAPI drift & coverage, importers.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./schema/*": "./schema/*"
  },
  "files": ["dist", "schema"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "gen:schema": "node scripts/emit-schema.mjs"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
